{
  "name": "syrix",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node -e \"const d=new Date(); require('fs').writeFileSync('src/lib/build-info.ts','// This file is regenerated at build time.\\nexport const BUILD_TIME = \\\"'+d.toISOString().replace('T',' ').slice(0,19)+'+03:00\\\";\\nexport const BUILD_VERSION = \\\"v0.1-dev\\\";\\n'); console.log('✓ Build info updated: '+d.toISOString());\" && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@next/swc-win32-x64-msvc": "^16.2.11",
    "@prisma/client": "^5.14.0",
    "@tanstack/react-query": "^5.40.0",
    "@upstash/ratelimit": "^1.1.0",
    "@upstash/redis": "^1.31.0",
    "clsx": "^2.1.0",
    "firebase": "^10.14.1",
    "firebase-admin": "^14.2.0",
    "lucide-react": "^0.378.0",
    "next": "^14.2.0",
    "next-intl": "^4.13.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwind-merge": "^2.3.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "jest": "^29.7.0",
    "postcss": "^8.4.0",
    "prisma": "^5.14.0",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.1.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0"
  }
